# Supabase — copia para .env.local e preenche.
# Usa SEMPRE a chave publicável (sb_publishable_...), NUNCA a service_role no frontend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Lodgify — chave de API SÓ do lado do servidor (nunca NEXT_PUBLIC).
# Usada pela sincronização de reservas das casas com fonte 'lodgify_api'.
LODGIFY_API_KEY=
